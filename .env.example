# =============================================================================
# Plataforma Cegonheiros - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values from your Supabase project.
# NEVER commit .env.local to version control.

# Supabase - Project URL
# Found in: Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase - Anonymous Key (safe for client-side)
# Found in: Supabase Dashboard > Settings > API > Project API keys > anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase - Service Role Key (server-side only, NEVER expose to client)
# Found in: Supabase Dashboard > Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL - Used for invitation redirect links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend - Email API Key (for future custom email templates)
# Sign up at: https://resend.com
# Currently optional: Supabase Auth handles invitation emails natively
RESEND_API_KEY=re_your-api-key-here
